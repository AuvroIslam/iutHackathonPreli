# Discord bot configuration (copy to bot/.env; .env is git-ignored)

# Required: your Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Optional: channel id the bot posts proactive alerts to (right-click channel -> Copy ID)
DISCORD_ALERT_CHANNEL_ID=

# Where the shared backend lives
BACKEND_URL=http://localhost:4000

# Optional LLM for friendly responses: none | groq | gemini
# Leave as "none" (or empty key) to use built-in templates.
LLM_PROVIDER=none
LLM_API_KEY=
# Optional model override (defaults: groq -> llama-3.1-8b-instant, gemini -> gemini-1.5-flash)
LLM_MODEL=
