# Discord bot configuration (copy to bot/.env; .env is git-ignored)

# Required: your Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=

# Optional: channel id the bot posts proactive alerts to (right-click channel -> Copy ID)
DISCORD_ALERT_CHANNEL_ID=

# Where the shared backend lives (local dev default below; use the Azure URL in prod)
BACKEND_URL=http://localhost:4000

# LLM humanizer: tries Groq first, then OpenAI, then built-in templates.
# Set a provider's API key to enable it; leave both blank to use templates only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
