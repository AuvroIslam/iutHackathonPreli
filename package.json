{
  "name": "office-energy-monitor",
  "version": "0.0.0",
  "private": true,
  "description": "Live office energy monitor with a shared backend, web dashboard and Discord bot.",
  "workspaces": [
    "shared",
    "backend",
    "dashboard",
    "bot"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspace=@office/backend && npm run build --workspace=@office/bot"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
